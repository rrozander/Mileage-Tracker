# Each Strava user needs their own API application.
# Add a block for each user with a unique suffix (e.g. RILEY, JASON).
STRAVA_CLIENT_ID_RILEY=your_client_id_here
STRAVA_CLIENT_SECRET_RILEY=your_client_secret_here
WEBHOOK_VERIFY_TOKEN_RILEY=pick_a_random_string

STRAVA_CLIENT_ID_JASON=your_client_id_here
STRAVA_CLIENT_SECRET_JASON=your_client_secret_here
WEBHOOK_VERIFY_TOKEN_JASON=pick_a_random_string

DATABASE_PATH=mileage.db
SEASON_START=04-01
SEASON_END=09-01
